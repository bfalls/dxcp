# Governance test harness configuration (local example only).
# Copy to .env.govtest and fill with real values; never commit secrets.

GOV_DXCP_UI_BASE=http://127.0.0.1:5173
GOV_DXCP_API_BASE=http://127.0.0.1:8000
GOV_AWS_REGION=us-east-1

GOV_AUTH0_DOMAIN=
GOV_AUTH0_AUDIENCE=
GOV_DXCP_UI_CLIENT_ID=

GOV_ADMIN_USERNAME=
GOV_ADMIN_PASSWORD=
GOV_OWNER_USERNAME=
GOV_OWNER_PASSWORD=
GOV_OBSERVER_USERNAME=
GOV_OBSERVER_PASSWORD=
GOV_CI_CLIENT_ID=
GOV_CI_CLIENT_SECRET=

# Optional deterministic run controls (Phase 1.7)
# If set, govtest will try this version first. If already registered, it falls
# back to computed bump to preserve Step C first-register behavior.
#
# Baseline artifact version used for prep copy when GOV_ARTIFACT_BASELINE_REF
# is not set.
# GOV_BASELINE_ARTIFACT_VERSION=0.1.18
#
# Key template used for both prep target/baseline selection and build
# registration payloads. Supports {service} and {version}.
# GOV_ARTIFACT_KEY_TEMPLATE=demo-service/demo-service-{version}.zip
#
# Optional explicit baseline artifact S3 URI (same bucket as discovered seed).
# GOV_ARTIFACT_BASELINE_REF=s3://<bucket>/demo-service/demo-service-0.1.18.zip

# Required for strict conformance; optional for diagnostic profile:
# non-member owner credentials for 403 DELIVERY_GROUP_SCOPE_REQUIRED probe on
# GET /v1/deployments/{id} during Step F.
GOV_NON_MEMBER_OWNER_USERNAME=
GOV_NON_MEMBER_OWNER_PASSWORD=

# Optional: safe (default) or active
GOV_GUARDRAILS_MODE=safe

# Optional auth-state TTL (minutes) for ui/e2e Playwright storageState refresh.
GOV_AUTH_STATE_MAX_AGE_MINUTES=240
